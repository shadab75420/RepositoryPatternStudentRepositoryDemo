@model IEnumerable<StudentRepositoryDemo.Models.Student>

<h2>Student List</h2>

<a asp-action="Create">Add Student</a>

<table class="table">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Course</th>
        <th>Age</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.StudentId</td>
            <td>@item.Name</td>
            <td>@item.Course</td>
            <td>@item.Age</td>
        </tr>
    }
</table>